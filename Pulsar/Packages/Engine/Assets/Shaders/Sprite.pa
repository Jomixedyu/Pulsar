{
    "$schema": "SbfSchema.json",
    "Interfaces": [
        "RENDERER_STATICMESH"
    ],
    "Passes": [
        {
            "Name": "Forward",
            "Entry": {
                "Vertex": "VSMain",
                "Fragment": "PSMain"
            },
            "Features": [
                "FEATURE_ALPHATEST"
            ],
            "GraphicsPipeline": {
                "CullMode": "Back",
                "ZWriteEnabled": true,
                "ZTestOp": "Less"
            }
        }
    ],
    "Properties": [
        {
            "Label": "Tint",
            "Name": "_TintColor",
            "Type": "Float4",
            "DefaultValue": "1,1,1,1",
            "Style": "Color"
        },
        {
            "Label": "EmissiveColor",
            "Name": "_EmissiveColor",
            "Type": "Float4",
            "DefaultValue": "0,0,0,1",
            "Style": "Color"
        },
        {
            "Label": "Base Color Map",
            "Name": "_BaseColorMap",
            "Type": "Texture2D",
            "DefaultValue": "T2D_WHITE"
        },
        {
            "Label": "Rows",
            "Name": "_Rows",
            "Type": "Float",
            "DefaultValue": "1"
        },
        {
            "Label": "Columns",
            "Name": "_Columns",
            "Type": "Float",
            "DefaultValue": "1"
        },
        {
            "Label": "Index",
            "Name": "_Index",
            "Type": "Float",
            "DefaultValue": "0"
        }
    ]
}
